# Configuración de APIs de IA (usa una)
# AI_PROVIDER: groq | ollama | gemini | openai

# GROQ - GRATIS, tier generoso (recomendado)
# https://console.groq.com/keys
GROQ_API_KEY=tu_api_key_de_groq

# Ollama - GRATIS, corre local (sin API key)
# Instala: https://ollama.com | Luego: ollama run llama3.2
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# Google Gemini
GOOGLE_AI_API_KEY=tu_api_key_de_google_ai

# OpenAI (ChatGPT)
OPENAI_API_KEY=tu_api_key_de_openai

# Por defecto: groq (gratis)
AI_PROVIDER=groq
